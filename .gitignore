__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
# Exception: CI-only vars file (no secrets, used by terraform-plan -backend=false)
!infra/azure/student-secure/terraform.ci.tfvars
!infra/azure/student-secure/intent.auto.tfvars
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Terraform plan binaries (covers both *.tfplan and bare `tfplan` generated by deploy job)
*.tfplan
**/tfplan

# Local Terraform config
.terraformrc
terraform.rc

# Secrets
.env
*.pem
*.key
config/opa/data/opa_auth_config.json

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
.trivy-cache/

# Security scan results
shift-left/trivy/results.json
shift-left/trivy/reports/
*.sarif
checkov_scan.log
tmp_ex.json

# Engine & Tests Output
shift-right/drift-engine/output/
ci/scripts/test-opa-zero-trust.sh

# CI scripts not wired to any pipeline job (local dev / one-shot use only)
ci/scripts/shift-left/trivy-config-scan.sh
ci/scripts/shift-left/test-one-finding-e2e.sh

# Windows NTFS case-insensitivity ghost — `infra/Azure` (capital A) duplicates `infra/azure`
infra/Azure/

# Environment settings
.env.drift
.claudecode
.claude

# Backups & IA Prompts / Diagnostics
*.backup
fix_report.json
test.yaml
test-policy.yaml
.gitlab-ci-diagnostics.yml
PROMPT_OPA_FIXES.md
CLAUDE.md

# Ignore all Markdown files by default
*.md
# EXCEPT mandatory documentation (Architecture standard)
!README.md
!*/README.md
!docs/SHIFT_LEFT_SCANNERS_DEEP_ANALYSIS.md

# Ignore Windows NTFS Alternate Data Streams (Downloads)
*.Zone.Identifier

# Windows WSL artifacts
*:Zone.Identifier

# Prowler CI artifacts — generated by pipeline, must not be versioned
shift-right/prowler/output/prowler-report.json

# Runtime outputs (regenerable)
output/
reports/

# Local test & verification artifacts (not in CI pipeline)
tests/
!shift-left/checkov/tests/
!shift-left/checkov/tests/validate-policy-catalog.py
!shift-right/drift-engine/tests/
shift-right/drift-engine/tests/*
!shift-right/drift-engine/tests/test_module_contracts.py
integration-tests/
