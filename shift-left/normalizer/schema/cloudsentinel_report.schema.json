{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CloudSentinel Golden Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "metadata",
    "summary",
    "scanners",
    "findings",
    "quality_gate",
    "intent_contract",
    "intent_mismatches"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "timestamp",
        "generation_duration_ms",
        "environment",
        "execution",
        "git",
        "normalizer"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "const": "cloudsentinel"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "generation_duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "environment": {
          "type": "string",
          "enum": ["dev", "test", "staging", "prod"]
        },
        "execution": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["ci", "local", "advisory"]
            }
          }
        },
        "git": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repo", "repository", "branch", "commit", "commit_date", "author_email", "pipeline_id"],
          "properties": {
            "repo": { "type": "string" },
            "repository": { "type": "string" },
            "branch": { "type": "string" },
            "commit": { "type": "string" },
            "commit_date": { "type": "string", "format": "date-time" },
            "author_email": { "type": "string", "format": "email" },
            "pipeline_id": { "type": "string" }
          }
        },
        "normalizer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "source_reports"],
          "properties": {
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "compatibility": {
              "type": "string",
              "enum": ["backward", "forward", "strict"],
              "description": "Schema evolution compatibility guarantee. backward: new fields added only, old consumers unaffected. forward: old fields may be removed. strict: schema frozen."
            },
            "source_reports": {
              "type": "object",
              "additionalProperties": false,
              "required": ["gitleaks", "checkov", "trivy"],
              "properties": {
                "gitleaks": { "$ref": "#/definitions/source_report_trace" },
                "checkov": { "$ref": "#/definitions/source_report_trace" },
                "trivy": { "$ref": "#/definitions/source_report_trace" }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global", "by_tool", "by_category"],
      "properties": {
        "global": {
          "$ref": "#/definitions/stats_summary"
        },
        "by_tool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["gitleaks", "checkov", "trivy"],
          "properties": {
            "gitleaks": { "$ref": "#/definitions/tool_summary" },
            "checkov": { "$ref": "#/definitions/tool_summary" },
            "trivy": { "$ref": "#/definitions/tool_summary" }
          }
        },
        "by_category": {
          "type": "object",
          "additionalProperties": false,
          "required": ["SECRETS", "INFRASTRUCTURE_AS_CODE", "VULNERABILITIES"],
          "properties": {
            "SECRETS": { "type": "integer", "minimum": 0 },
            "INFRASTRUCTURE_AS_CODE": { "type": "integer", "minimum": 0 },
            "VULNERABILITIES": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "scanners": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gitleaks", "checkov", "trivy"],
      "properties": {
        "gitleaks": { "$ref": "#/definitions/scanner" },
        "checkov": { "$ref": "#/definitions/scanner" },
        "trivy": { "$ref": "#/definitions/scanner" }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/finding" }
    },
    "intent_contract": {
      "description": "Contrat d'intention déclaré dans intent.tf. Null si absent (MISSING_INTENT_CONTRACT déclenche un deny OPA).",
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["declared", "violation"],
      "properties": {
        "declared": {
          "description": "Champs resource_intent extraits du plan Terraform. Null si le plan n'est pas disponible.",
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["service_type", "exposure_level", "owner", "approved_by"],
          "properties": {
            "service_type":   { "type": "string", "enum": ["web-server", "database", "cache", "worker", "gateway"] },
            "exposure_level": { "type": "string", "enum": ["internet-facing", "internal-only", "isolated"] },
            "owner":          { "type": "string", "minLength": 1 },
            "approved_by":    { "type": "string", "minLength": 1 }
          }
        },
        "violation": {
          "description": "Code de violation si le contrat est absent ou invalide. Ex: MISSING_INTENT_CONTRACT.",
          "type": ["string", "null"],
          "enum": [null, "MISSING_INTENT_CONTRACT", "EMPTY_INTENT_CONTRACT_FIELDS", "INVALID_INTENT_CONTRACT"]
        }
      }
    },
    "intent_mismatches": {
      "description": "Liste des écarts détectés entre l'intention déclarée et les findings des scanners (role spoofing, exposure mismatch).",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule", "severity", "declared", "observed", "mitre", "source_findings"],
        "properties": {
          "rule":            { "type": "string" },
          "severity":        { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"] },
          "declared":        { "type": "string" },
          "observed":        { "type": "string" },
          "mitre":           { "type": "string" },
          "source_findings": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "quality_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "reason", "thresholds"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["PASSED", "FAILED", "NOT_EVALUATED"]
        },
        "reason": {
          "type": "string"
        },
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["critical_max", "high_max"],
          "properties": {
            "critical_max": { "type": "integer", "minimum": 0 },
            "high_max": { "type": "integer", "minimum": 0 }
          }
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "reasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "not_run_scanners": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "stats_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "CRITICAL",
        "HIGH",
        "MEDIUM",
        "LOW",
        "INFO",
        "TOTAL",
        "EXEMPTED",
        "FAILED",
        "PASSED"
      ],
      "properties": {
        "CRITICAL": { "type": "integer", "minimum": 0 },
        "HIGH": { "type": "integer", "minimum": 0 },
        "MEDIUM": { "type": "integer", "minimum": 0 },
        "LOW": { "type": "integer", "minimum": 0 },
        "INFO": { "type": "integer", "minimum": 0 },
        "TOTAL": { "type": "integer", "minimum": 0 },
        "EXEMPTED": { "type": "integer", "minimum": 0 },
        "FAILED": { "type": "integer", "minimum": 0 },
        "PASSED": { "type": "integer", "minimum": 0 }
      }
    },
    "tool_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "CRITICAL",
        "HIGH",
        "MEDIUM",
        "LOW",
        "INFO",
        "TOTAL",
        "EXEMPTED",
        "FAILED",
        "PASSED",
        "status"
      ],
      "properties": {
        "CRITICAL": { "type": "integer", "minimum": 0 },
        "HIGH": { "type": "integer", "minimum": 0 },
        "MEDIUM": { "type": "integer", "minimum": 0 },
        "LOW": { "type": "integer", "minimum": 0 },
        "INFO": { "type": "integer", "minimum": 0 },
        "TOTAL": { "type": "integer", "minimum": 0 },
        "EXEMPTED": { "type": "integer", "minimum": 0 },
        "FAILED": { "type": "integer", "minimum": 0 },
        "PASSED": { "type": "integer", "minimum": 0 },
        "status": {
          "type": "string",
          "enum": ["PASSED", "FAILED", "NOT_RUN"]
        }
      }
    },
    "source_report_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "path", "present", "valid_json", "status", "reason", "sha256"],
      "properties": {
        "tool": { "type": "string", "enum": ["gitleaks", "checkov", "trivy"] },
        "path": { "type": "string" },
        "present": { "type": "boolean" },
        "valid_json": { "type": "boolean" },
        "status": { "type": "string", "enum": ["PASSED", "FAILED", "NOT_RUN"] },
        "reason": { "type": "string" },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "scanner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "version", "status", "errors", "stats", "findings"],
      "properties": {
        "tool": { "type": "string" },
        "version": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["PASSED", "FAILED", "NOT_RUN"]
        },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stats": { "$ref": "#/definitions/stats_summary" },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/definitions/finding" }
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source",
        "resource",
        "description",
        "severity",
        "category",
        "status",
        "remediation",
        "context"
      ],
      "properties": {
        "id": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW"],
          "description": "Deterministic confidence level of the detection, set by the normalizer based on scanner type. Never computed at runtime or modified downstream."
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tool", "version", "id", "scanner_type"],
          "properties": {
            "tool": { "type": "string" },
            "version": { "type": "string" },
            "id": { "type": "string" },
            "scanner_type": { "type": "string" }
          }
        },
        "resource": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "type", "path", "location"],
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" },
            "type": { "type": "string" },
            "path": { "type": "string" },
            "location": {
              "type": "object",
              "additionalProperties": false,
              "required": ["file", "start_line", "end_line"],
              "properties": {
                "file": { "type": "string" },
                "start_line": { "type": "integer", "minimum": 0 },
                "end_line": { "type": "integer", "minimum": 0 }
              }
            }
          }
        },
        "description": { "type": "string" },
        "severity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "original_severity"],
          "properties": {
            "level": {
              "type": "string",
              "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]
            },
            "original_severity": { "type": "string" },
            "cvss_score": { "type": ["number", "null"] }
          }
        },
        "category": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["PASSED", "FAILED"],
          "description": "Immutable detection status set by the normalizer. PASSED = scanner explicit pass (e.g. Trivy misconfig). FAILED = active finding requiring evaluation. Duplicate tracking is via context.deduplication.is_duplicate — NOT via status. EXEMPTED is deprecated as of v1.2.1 and no longer produced by the normalizer."
        },
        "remediation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sla_hours", "fix_version", "references"],
          "properties": {
            "sla_hours": { "type": "integer", "minimum": 0 },
            "fix_version": { "type": "string" },
            "references": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["git", "deduplication", "traceability"],
          "properties": {
            "git": {
              "type": "object",
              "additionalProperties": false,
              "required": ["author_email", "commit_date"],
              "properties": {
                "author_email": { "type": "string", "format": "email" },
                "commit_date": { "type": "string", "format": "date-time" }
              }
            },
            "deduplication": {
              "type": "object",
              "additionalProperties": false,
              "required": ["fingerprint", "is_duplicate", "duplicate_of"],
              "properties": {
                "fingerprint": { "type": "string" },
                "is_duplicate": { "type": "boolean" },
                "duplicate_of": {
                  "type": ["string", "null"]
                }
              }
            },
            "traceability": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_report", "source_index", "normalized_at"],
              "properties": {
                "source_report": { "type": "string" },
                "source_index": { "type": "integer", "minimum": 0 },
                "normalized_at": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      }
    }
  }
}
