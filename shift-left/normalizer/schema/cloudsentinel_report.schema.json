{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CloudSentinel Golden Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scan_id",
    "scan_status",
    "metadata",
    "summary",
    "scanners",
    "findings",
    "quality_gate",
    "resources_analyzed"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "scan_id": {
      "type": "string",
      "minLength": 7
    },
    "scan_status": {
      "type": "string",
      "enum": ["success", "failure"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "timestamp",
        "scan_id",
        "executed_scanners",
        "generation_duration_ms",
        "environment",
        "execution",
        "git",
        "normalizer"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "const": "cloudsentinel"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "scan_id": {
          "type": "string",
          "minLength": 7
        },
        "executed_scanners": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["gitleaks", "checkov", "trivy", "cloudinit"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "generation_duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "environment": {
          "type": "string",
          "enum": ["dev", "test", "staging", "prod"]
        },
        "execution": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["ci", "local", "advisory"]
            }
          }
        },
        "git": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "branch", "commit", "commit_date", "author_email", "pipeline_id"],
          "properties": {
            "repository": { "type": "string" },
            "branch": { "type": "string" },
            "commit": { "type": "string" },
            "commit_date": { "type": "string", "format": "date-time" },
            "author_email": { "type": "string", "format": "email" },
            "pipeline_id": { "type": "string" }
          }
        },
        "normalizer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "source_reports"],
          "properties": {
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "compatibility": {
              "type": "string",
              "enum": ["backward", "forward", "strict"],
              "description": "Schema evolution compatibility guarantee. backward: new fields added only, old consumers unaffected. forward: old fields may be removed. strict: schema frozen."
            },
            "source_reports": {
              "type": "object",
              "additionalProperties": false,
              "required": ["gitleaks", "checkov", "trivy", "cloudinit"],
              "properties": {
                "gitleaks": { "$ref": "#/definitions/source_report_trace" },
                "checkov": { "$ref": "#/definitions/source_report_trace" },
                "trivy": { "$ref": "#/definitions/source_report_trace" },
                "cloudinit": { "$ref": "#/definitions/source_report_trace" }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global", "by_tool", "by_category"],
      "properties": {
        "global": {
          "$ref": "#/definitions/stats_summary"
        },
        "by_tool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["gitleaks", "checkov", "trivy", "cloudinit"],
          "properties": {
            "gitleaks": { "$ref": "#/definitions/tool_summary" },
            "checkov": { "$ref": "#/definitions/tool_summary" },
            "trivy": { "$ref": "#/definitions/tool_summary" },
            "cloudinit": { "$ref": "#/definitions/tool_summary" }
          }
        },
        "by_category": {
          "type": "object",
          "additionalProperties": false,
          "required": ["SECRETS", "INFRASTRUCTURE_AS_CODE", "VULNERABILITIES"],
          "properties": {
            "SECRETS": { "type": "integer", "minimum": 0 },
            "INFRASTRUCTURE_AS_CODE": { "type": "integer", "minimum": 0 },
            "VULNERABILITIES": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "scanners": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gitleaks", "checkov", "trivy", "cloudinit"],
      "properties": {
        "gitleaks": { "$ref": "#/definitions/scanner" },
        "checkov": { "$ref": "#/definitions/scanner" },
        "trivy": { "$ref": "#/definitions/scanner" },
        "cloudinit": { "$ref": "#/definitions/scanner" }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/finding" }
    },
    "resources_analyzed": {
      "description": "Résultats du scanner cloud-init corrélés par ressource VM.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "resource_address",
          "resource_type",
          "resource_name",
          "file",
          "environment",
          "role_tag",
          "cloud_init_field",
          "signals",
          "violations"
        ],
        "properties": {
          "resource_address": { "type": "string", "minLength": 1 },
          "resource_type": { "type": "string", "minLength": 1 },
          "resource_name": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 0 },
          "environment": { "type": "string", "enum": ["dev", "test", "staging", "prod"] },
          "role_tag": { "type": ["string", "null"] },
          "cloud_init_field": { "type": ["string", "null"] },
          "signals": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "role_tag_missing",
              "role_spoofing_candidate",
              "remote_exec_detected",
              "db_packages_detected",
              "remote_exec_patterns",
              "security_bypass_detected",
              "security_bypass_patterns"
            ],
            "properties": {
              "role_tag_missing": { "type": "boolean" },
              "role_spoofing_candidate": { "type": "boolean" },
              "remote_exec_detected": { "type": "boolean" },
              "db_packages_detected": { "type": "array", "items": { "type": "string" } },
              "remote_exec_patterns": { "type": "array", "items": { "type": "string" } },
              "security_bypass_detected": { "type": "boolean" },
              "security_bypass_patterns": { "type": "array", "items": { "type": "string" } },
              "cloud_init_unresolvable": { "type": "boolean" }
            }
          },
          "violations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["rule", "severity", "message", "non_waivable_in_prod", "block"],
              "properties": {
                "rule": { "type": "string", "minLength": 1 },
                "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"] },
                "message": { "type": "string", "minLength": 1 },
                "non_waivable_in_prod": { "type": "boolean" },
                "block": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "quality_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["thresholds"],
      "properties": {
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["critical_max", "high_max"],
          "properties": {
            "critical_max": { "type": "integer", "minimum": 0 },
            "high_max": { "type": "integer", "minimum": 0 }
          }
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "not_run_scanners": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "stats_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "CRITICAL",
        "HIGH",
        "MEDIUM",
        "LOW",
        "INFO",
        "TOTAL",
        "EXEMPTED",
        "FAILED",
        "PASSED"
      ],
      "properties": {
        "CRITICAL": { "type": "integer", "minimum": 0 },
        "HIGH": { "type": "integer", "minimum": 0 },
        "MEDIUM": { "type": "integer", "minimum": 0 },
        "LOW": { "type": "integer", "minimum": 0 },
        "INFO": { "type": "integer", "minimum": 0 },
        "TOTAL": { "type": "integer", "minimum": 0 },
        "EXEMPTED": { "type": "integer", "minimum": 0 },
        "FAILED": { "type": "integer", "minimum": 0 },
        "PASSED": { "type": "integer", "minimum": 0 }
      }
    },
    "tool_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "CRITICAL",
        "HIGH",
        "MEDIUM",
        "LOW",
        "INFO",
        "TOTAL",
        "EXEMPTED",
        "FAILED",
        "PASSED",
        "status"
      ],
      "properties": {
        "CRITICAL": { "type": "integer", "minimum": 0 },
        "HIGH": { "type": "integer", "minimum": 0 },
        "MEDIUM": { "type": "integer", "minimum": 0 },
        "LOW": { "type": "integer", "minimum": 0 },
        "INFO": { "type": "integer", "minimum": 0 },
        "TOTAL": { "type": "integer", "minimum": 0 },
        "EXEMPTED": { "type": "integer", "minimum": 0 },
        "FAILED": { "type": "integer", "minimum": 0 },
        "PASSED": { "type": "integer", "minimum": 0 },
        "status": {
          "type": "string",
          "enum": ["PASSED", "FAILED", "NOT_RUN"]
        }
      }
    },
    "source_report_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "path", "present", "valid_json", "status", "reason", "sha256"],
      "properties": {
        "tool": { "type": "string", "enum": ["gitleaks", "checkov", "trivy", "cloudinit"] },
        "path": { "type": "string" },
        "present": { "type": "boolean" },
        "valid_json": { "type": "boolean" },
        "status": { "type": "string", "enum": ["PASSED", "FAILED", "NOT_RUN"] },
        "reason": { "type": "string" },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "scanner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "version", "status", "errors", "stats", "findings"],
      "properties": {
        "tool": { "type": "string" },
        "version": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["PASSED", "FAILED", "NOT_RUN"]
        },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stats": { "$ref": "#/definitions/stats_summary" },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/definitions/finding" }
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source",
        "resource",
        "description",
        "severity",
        "category",
        "status",
        "remediation",
        "context"
      ],
      "properties": {
        "id": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW"],
          "description": "Deterministic confidence level of the detection, set by the normalizer based on scanner type. Never computed at runtime or modified downstream."
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tool", "version", "id", "scanner_type"],
          "properties": {
            "tool": { "type": "string" },
            "version": { "type": "string" },
            "id": { "type": "string" },
            "scanner_type": { "type": "string" }
          }
        },
        "resource": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "type", "path", "location"],
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" },
            "type": { "type": "string" },
            "path": { "type": "string" },
            "location": {
              "type": "object",
              "additionalProperties": false,
              "required": ["file", "start_line", "end_line"],
              "properties": {
                "file": { "type": "string" },
                "start_line": { "type": "integer", "minimum": 0 },
                "end_line": { "type": "integer", "minimum": 0 }
              }
            }
          }
        },
        "description": { "type": "string" },
        "severity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "original_severity"],
          "properties": {
            "level": {
              "type": "string",
              "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]
            },
            "original_severity": { "type": "string" },
            "cvss_score": { "type": ["number", "null"] }
          }
        },
        "category": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["PASSED", "FAILED"],
          "description": "Immutable detection status set by the normalizer. PASSED = scanner explicit pass (e.g. Trivy misconfig). FAILED = active finding requiring evaluation. Duplicate tracking is via context.deduplication.is_duplicate — NOT via status. EXEMPTED is deprecated as of v1.2.1 and no longer produced by the normalizer."
        },
        "remediation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sla_hours", "fix_version", "references"],
          "properties": {
            "sla_hours": { "type": "integer", "minimum": 0 },
            "fix_version": { "type": "string" },
            "references": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["git", "deduplication", "traceability"],
          "properties": {
            "git": {
              "type": "object",
              "additionalProperties": false,
              "required": ["author_email", "commit_date", "in_latest_push"],
              "properties": {
                "author_email": { "type": "string", "format": "email" },
                "commit_date": { "type": "string", "format": "date-time" },
                "in_latest_push": {
                  "type": "boolean",
                  "description": "True for all non-gitleaks findings. For gitleaks: true = introduced in the current push (blocks pipeline), false = historical finding (advisory only, never blocks)."
                }
              }
            },
            "deduplication": {
              "type": "object",
              "additionalProperties": false,
              "required": ["fingerprint", "is_duplicate", "duplicate_of"],
              "properties": {
                "fingerprint": { "type": "string" },
                "is_duplicate": { "type": "boolean" },
                "duplicate_of": {
                  "type": ["string", "null"]
                }
              }
            },
            "traceability": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_report", "source_index", "normalized_at"],
              "properties": {
                "source_report": { "type": "string" },
                "source_index": { "type": "integer", "minimum": 0 },
                "normalized_at": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      }
    }
  }
}
