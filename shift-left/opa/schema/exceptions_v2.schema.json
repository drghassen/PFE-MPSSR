{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CloudSentinel Exceptions v2 (DefectDojo Compatible)",
  "type": "object",
  "additionalProperties": false,
  "required": ["cloudsentinel"],
  "properties": {
    "cloudsentinel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exceptions"],
      "properties": {
        "exceptions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_version", "generated_at", "exceptions"],
          "properties": {
            "schema_version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "generated_at": {
              "type": "string",
              "format": "date-time"
            },
            "metadata": {
              "type": "object"
            },
            "exceptions": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/exception_v2"
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "exception_v2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tool",
        "rule_id",
        "resource",
        "severity",
        "requested_by",
        "approved_by",
        "approved_at",
        "expires_at",
        "decision",
        "source",
        "status",
        "occurrence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "tool": {
          "type": "string",
          "enum": ["checkov", "trivy", "gitleaks"]
        },
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "resource": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]
        },
        "requested_by": {
          "type": "string",
          "minLength": 1
        },
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "decision": {
          "type": "string",
          "enum": ["accept", "mitigate", "fix", "transfer", "avoid"]
        },
        "source": {
          "type": "string",
          "const": "defectdojo"
        },
        "status": {
          "type": "string",
          "const": "approved"
        },
        "occurrence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["file_path", "line"],
          "properties": {
            "file_path": {
              "type": "string",
              "minLength": 1
            },
            "line": {
              "type": "integer",
              "minimum": 0
            },
            "hash_code": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "finding_id": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "scope": {
          "type": "object",
          "description": "CI pipeline context injected at fetch time. Not stored in DefectDojo.",
          "additionalProperties": false,
          "properties": {
            "repos": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "description": "Empty = no repo restriction. Populated from CI_PROJECT_PATH."
            },
            "branches": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "description": "Empty = no branch restriction. Populated from CI_COMMIT_REF_NAME."
            },
            "environments": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["dev", "test", "staging", "prod"]
              },
              "description": "Empty = no environment restriction. Populated from CI_ENVIRONMENT_NAME."
            }
          }
        }
      }
    }
  }
}
