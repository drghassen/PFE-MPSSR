{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Checkov Custom YAML Policy",
  "type": "object",
  "required": ["metadata", "definition"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["id", "name", "category", "severity"],
      "additionalProperties": true,
      "properties": {
        "id":        { "type": "string", "pattern": "^CKV2?_" },
        "name":      { "type": "string" },
        "category":  { "type": "string" },
        "severity":  { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"] },
        "guideline": { "type": "string" }
      }
    },
    "definition": {
      "type": "object",
      "properties": {
        "cond_type":       { "type": "string", "enum": ["attribute", "connection", "filter", "and", "or", "not"] },
        "resource_types":  { "type": "array", "items": { "type": "string" } },
        "attribute":       { "type": "string" },
        "operator":        { "type": "string" },
        "value":           {},
        "and":             { "type": "array" },
        "or":              { "type": "array" },
        "not":             { "type": "array" },
        "connected_resource_types": { "type": "array", "items": { "type": "string" } },
        "connection_type": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
