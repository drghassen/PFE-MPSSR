# CloudSentinel local environment template.
# Copy to .env and fill only the values needed for your local workflow.

# General execution
ENVIRONMENT=dev
CLOUDSENTINEL_EXECUTION_MODE=local
CLOUDSENTINEL_FAIL_CLOSED=true
CLOUDSENTINEL_HMAC_SECRET=change-me-local-only

# Terraform / Azure
ARM_SUBSCRIPTION_ID=
ARM_TENANT_ID=
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=
TF_WORKING_DIR=infra/azure/envs/dev
TF_WORKSPACE=default

# DefectDojo external service
DOJO_URL=
DOJO_API_KEY=
DOJO_ENGAGEMENT_ID=
DOJO_ENGAGEMENT_ID_RIGHT=
DEFECTDOJO_URL=
DEFECTDOJO_API_KEY=
DEFECTDOJO_ENGAGEMENT_ID_LEFT=
DEFECTDOJO_ENGAGEMENT_ID_RIGHT=

# OPA local servers
OPA_SERVER_URL=http://localhost:8181
OPA_AUTH_TOKEN=

# Shift-right
DRIFT_ENVIRONMENT=production
PROWLER_ENVIRONMENT=production
REMEDIATION_MODE=advisory
CUSTODIAN_DRY_RUN=true
