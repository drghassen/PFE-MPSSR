subscription_id      = "00000000-0000-0000-0000-000000000000"
location             = "westeurope"
name_prefix          = "cs-dev"
vnet_cidr            = "10.42.0.0/16"
public_subnet_cidr   = "10.42.1.0/24"
private_subnet_cidr  = "10.42.2.0/24"

# Disabled: saves ~$35/month on student account
create_nat_gateway   = false

# VM in public subnet with public IP for easy dev access
assign_public_ip     = true
allow_http_inbound   = true

# Student-friendly VM size (1 vCPU, 2GB RAM)
vm_size              = "Standard_B1s"

ssh_allowed_cidr     = "0.0.0.0/0"
admin_username       = "cloudsentinel"
admin_ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIReplaceWithYourPublicKey cloudsentinel"

create_ci_identity   = true
log_retention_days   = 30

# Database — PostgreSQL Flexible Server Burstable B1ms (~$13/month)
db_admin_login    = "csadmin"
db_admin_password = "ReplaceWithStrongPassword123!"
db_sku_name       = "B_Standard_B1ms"
db_name           = "cloudsentinel"
# Step 1: apply with empty list
# Step 2: add VM public IP (from output vm_public_ip) + your own IP
db_allowed_ips    = ["YOUR_VM_PUBLIC_IP", "YOUR_OWN_IP"]

# Optional extra tags
# tags = {
#   cost_center = "secops"
#   owner_team  = "cloud-platform"
# }
