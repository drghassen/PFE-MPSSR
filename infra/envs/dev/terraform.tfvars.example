subscription_id      = "00000000-0000-0000-0000-000000000000"
location             = "westeurope"
name_prefix          = "cs-dev"
vnet_cidr            = "10.42.0.0/16"
public_subnet_cidr   = "10.42.1.0/24"
private_subnet_cidr  = "10.42.2.0/24"

# Disabled: saves ~$35/month on student account
create_nat_gateway   = false

# Keep VM private by default (recommended)
assign_public_ip     = false
allow_http_inbound   = false

# Student-friendly VM size (1 vCPU, 2GB RAM)
vm_size              = "Standard_B1s"

ssh_allowed_cidr     = "203.0.113.10/32"
admin_username       = "cloudsentinel"
admin_ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAACAQReplaceWithYourPublicKey cloudsentinel"

create_ci_identity   = true
log_retention_days   = 30

# Database — PostgreSQL Flexible Server Burstable B1ms (~$13/month)
db_admin_login    = "csadmin"
db_admin_password = "REPLACE_IN_CI_MASKED_VARIABLE"
db_sku_name       = "B_Standard_B1ms"
db_name           = "cloudsentinel"
db_allowed_ips    = []

