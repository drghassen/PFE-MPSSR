# ---- Azure authentication for Terraform (Service Principal) ----
# Required for SP auth:
# ARM_CLIENT_ID=
# ARM_CLIENT_SECRET=
# ARM_TENANT_ID=
# ARM_SUBSCRIPTION_ID=
#
# Optional for Managed Identity auth:
# ARM_USE_MSI=true
# ARM_CLIENT_ID=   # user-assigned MI client id (optional)

# ---- Drift engine runtime ----
TF_WORKING_DIR=/work/iac
TF_DATA_DIR=/tmp/cloudsentinel-tfdata
TF_WORKSPACE=default
DRIFT_CONFIG_PATH=/app/config/drift_config.yaml
DRIFT_OUTPUT_PATH=/work/output/drift-report.json
# DefectDojo push is mandatory for traceability (do not disable).
# Override plan timeout in seconds (default: 600)
# TF_PLAN_TIMEOUT_S=600
# Terraform/OpenTofu binary selection (auto-detected if unset)
# TF_BINARY=tofu
# Optional: Terraform dependency lockfile behavior for `terraform init`.
# - readonly (recommended when mounting IaC read-only; requires existing .terraform.lock.hcl)
# TF_LOCKFILE_MODE=readonly

# docker-compose helper (path to your Terraform project on host)
# TF_IAC_PATH=../../infra/azure/student-secure

# Optional: backend config if your Terraform code uses `backend "azurerm" {}` without inline values.
# Easiest form (recommended):
# TF_BACKEND_RESOURCE_GROUP_NAME=rg-terraform-state
# TF_BACKEND_STORAGE_ACCOUNT_NAME=sttfstateghassen01
# TF_BACKEND_CONTAINER_NAME=tfstate
# TF_BACKEND_KEY=student-secure-main.tfstate
# TF_BACKEND_USE_AZUREAD_AUTH=true
#
# Advanced: JSON map (optional)
# TF_BACKEND_CONFIG_JSON={"resource_group_name":"rg-terraform-state","storage_account_name":"sttfstateghassen01","container_name":"tfstate","key":"student-secure-main.tfstate","use_azuread_auth":"true"}

# ---- DefectDojo (v2 API) ----
# Required
# DEFECTDOJO_URL=http://host.docker.internal:8080
# DEFECTDOJO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEFECTDOJO_ENGAGEMENT_ID=1

# Terraform/OpenTofu plan timeout in seconds (default: 600)
# TF_PLAN_TIMEOUT_S=600
